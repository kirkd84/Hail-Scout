# HailScout API Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://hailscout:hailscout@postgres:5432/hailscout
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600

# Clerk Authentication
CLERK_SECRET_KEY=<your-clerk-secret-key>
CLERK_JWKS_ENDPOINT=https://your-instance.clerk.accounts.com/.well-known/jwks.json

# Server
ENV=development
DEBUG=true
PORT=8000
LOG_LEVEL=INFO

# Geocoding (Nominatim for MVP, Mapbox in future)
GEOCODER_PROVIDER=nominatim
NOMINATIM_USER_AGENT=HailScout/0.1.0 (+https://hailscout.com)
MAPBOX_API_KEY=<your-clerk-publishable-key>

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# AWS (for future S3 storage of reports, tiles)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS (allow frontend domains)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
