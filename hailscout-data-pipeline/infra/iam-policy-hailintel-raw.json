{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "HailScoutRawListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::hailscout-raw"
      ]
    },
    {
      "Sid": "HailScoutRawPutObject",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::hailscout-raw/mesh/*"
      ]
    }
  ]
}
