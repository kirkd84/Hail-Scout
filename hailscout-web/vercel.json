{
  "version": 2,
  "name": "hailscout-web",
  "rootDirectory": "hailscout-web",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": {
      "description": "Clerk publishable key from clerk.com dashboard"
    },
    "CLERK_SECRET_KEY": {
      "description": "Clerk secret key from clerk.com dashboard"
    },
    "NEXT_PUBLIC_API_BASE_URL": {
      "description": "Backend API base URL (e.g., https://api.hailscout.com)",
      "default": "https://api.hailscout.com"
    },
    "NEXT_PUBLIC_TILES_BASE_URL": {
      "description": "Tiles service base URL (e.g., https://tiles.hailscout.com)",
      "default": "https://tiles.hailscout.com"
    },
    "NEXT_PUBLIC_MAP_CENTER_LAT": {
      "description": "Map center latitude (continental US default)",
      "default": "39.8"
    },
    "NEXT_PUBLIC_MAP_CENTER_LNG": {
      "description": "Map center longitude (continental US default)",
      "default": "-98.58"
    },
    "NEXT_PUBLIC_MAP_DEFAULT_ZOOM": {
      "description": "Map default zoom level",
      "default": "4"
    },
    "NEXT_PUBLIC_ENABLE_CANVASSING": {
      "description": "Enable canvassing features",
      "default": "false"
    },
    "NEXT_PUBLIC_ENABLE_REPORTS": {
      "description": "Enable report generation",
      "default": "false"
    },
    "NEXT_PUBLIC_ENABLE_AI_FEATURES": {
      "description": "Enable AI features",
      "default": "false"
    }
  },
  "domains": ["app.hailscout.com"]
}
