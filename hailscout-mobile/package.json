{
  "name": "hailscout-mobile",
  "version": "1.0.0",
  "description": "HailScout mobile app for storm restoration contractors",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "submit:android": "eas submit --platform android --latest"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^0.20.0",
    "@clerk/clerk-react-native": "^0.20.0",
    "@maplibre/maplibre-react-native": "^10.0.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/stack": "^6.4.0",
    "expo": "^52.0.0",
    "expo-linking": "^6.3.0",
    "expo-location": "^17.1.0",
    "expo-splash-screen": "^0.27.0",
    "expo-status-bar": "^1.12.0",
    "expo-secure-store": "^13.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.27.0",
    "zod": "^3.22.0",
    "react-native-svg": "^15.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.76.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.0",
    "typescript": "^5.1.0"
  }
}
