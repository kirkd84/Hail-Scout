{
  "name": "hailscout-mobile",
  "version": "1.0.0",
  "description": "HailScout mobile app for storm restoration contractors",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "submit:android": "eas submit --platform android --latest"
  },
  "dependencies": {
    "@maplibre/maplibre-react-native": "^11.3.6",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "expo": "^57.0.0",
    "expo-auth-session": "~57.0.1",
    "expo-build-properties": "~57.0.2",
    "expo-crypto": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.1",
    "expo-notifications": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-speech": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "typescript": "^5.1.0"
  },
  "overrides": {
    "react-test-renderer": "$react"
  }
}
