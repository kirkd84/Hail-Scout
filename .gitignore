# ──────────────────────────────────────────────────────────────────────
# HailScout monorepo — root .gitignore
# Each sub-repo also has its own .gitignore for its specific stack.
# ──────────────────────────────────────────────────────────────────────

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# Secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.p12
*.keystore
*.key
google-services.json
GoogleService-Info.plist

# ──────────────────────────────────────────────────────────────────────
# Python (data-pipeline, api, tiles)
# ──────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
.venv/lib/
.venv/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.venv/
venv/
env/
ENV/

# Poetry / pip caches
.poetry/
pip-wheel-metadata/

# Testing / linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# ──────────────────────────────────────────────────────────────────────
# Node / Next.js / Expo (web, mobile)
# ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js
.next/
out/
.vercel/

# Expo
.expo/
.expo-shared/
dist/
web-build/

# EAS / native build artifacts
ios/Pods/
ios/build/
android/.gradle/
android/build/
android/app/build/
android/app/release/
*.ipa
*.apk
*.aab

# ──────────────────────────────────────────────────────────────────────
# Tile / GIS artifacts
# ──────────────────────────────────────────────────────────────────────
*.mbtiles
*.pbf
*.tif
*.tiff
*.grib2
*.gpkg
hailscout-tiles/output/
hailscout-tiles/tmp/

# Real MRMS / NEXRAD fixtures — too big for git
hailscout-data-pipeline/tests/fixtures/local_fixtures/
hailscout-data-pipeline/tests/fixtures/*.grib2
hailscout-data-pipeline/tests/fixtures/*.tif

# ──────────────────────────────────────────────────────────────────────
# AWS / Terraform
# ──────────────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
.terraformrc
terraform.rc
.aws-sam/
samconfig.toml

# ──────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────
logs/
*.log
